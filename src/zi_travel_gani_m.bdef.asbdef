managed;//implementation in class zbp_i_travel_gani_m unique;
strict ( 2 );

define behavior for zi_travel_gani_m // alias Travel
implementation in class zcl_bp_travel_gani_m unique
persistent table ztravel_ganesh_m
lock master
authorization master ( instance )
etag master LastChangedAt
{
  create ( authorization : global );
  update;
  delete;
  //  field ( readonly ) TravelId;
  association _Booking { create; }
  mapping for ztravel_ganesh_m
    {
      TravelId      = travel_id;
      AgencyId      = agency_id;
      CustomerId    = customer_id;
      BeginDate     = begin_date;
      EndDate       = end_date;
      BookingFee    = booking_fee;
      TotalPrice    = total_price;
      CurrencyCode  = currency_code;
      Description   = description;
      OverallStatus = overall_status;
      CreatedBy     = created_by;
      CreatedAt     = created_at;
      LastChangedBy = last_changed_by;
      LastChangedAt = last_changed_at;
    }
}

define behavior for zi_booking_gani_m //alias <alias_name>
implementation in class zcl_bp_booking_gani_m unique
persistent table zbooking_gani_m
lock dependent by _Travel
authorization dependent by _Travel
etag master LastChangedAt
{
  update;
  delete;
  field ( readonly ) TravelId;//, BookingId;
  association _Travel;
  association _BookingSuppl { create; }
  mapping for zbooking_gani_m
    {
      TravelId      = travel_id;
      BookingId     = booking_id;
      BookingDate   = booking_date;
      CustomerId    = customer_id;
      CarrierId     = carrier_id;
      ConnectionId  = connection_id;
      FlightDate    = flight_date;
      FlightPrice   = flight_price;
      CurrencyCode  = currency_code;
      BookingStatus = booking_status;
      LastChangedAt = last_changed_at;
    }
}

define behavior for zi_booksuppl_gani_m //alias <alias_name>
implementation in class zcl_bp_booksuppl_gani_m unique
persistent table zbooksupp_gani_m
lock dependent by _travel
authorization dependent by _travel
etag master LastChangedAt
{
  update;
  delete;
  field ( readonly ) TravelId, BookingId;//, BookingSupplementId;
  association _travel;
  association _booking;
  mapping for zbooksupp_gani_m
    {
      TravelId            = travel_id;
      BookingId           = booking_id;
      BookingSupplementId = booking_supplement_id;
      SupplementId        = supplement_id;
      Price               = price;
      CurrencyCode        = currency_code;
      LastChangedAt       = last_changed_at;
    }
}